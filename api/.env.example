# api/.env.example
# Copiază în api/.env.local și completează valorile.
# NOTĂ: API-ul NU încarcă singur acest fișier (nu există dotenv) — pornește-l cu:
#   node --env-file=api/.env.local api/dist/index.js

# ==============================
# Auth (obligatorii)
# ==============================
# Secretul HMAC pentru tokenurile controlcenter. Generează cu: openssl rand -hex 32
TAXI_AUTH_TOKEN_SECRET=generate-with-openssl-rand-hex-32

# PIN-ul HQ (scope global) — 4 cifre.
TAXI_CONTROL_CENTER_HQ_PIN=0000

# Orașul "de casă" al sesiunii HQ (slug existent în directory-ul de orașe).
TAXI_CONTROL_CENTER_HQ_CITY_ID=baia-mare

# PIN-uri per oraș (scope city) — JSON pe o singură linie: {"<city-slug>":"<pin>"}.
TAXI_CONTROL_CENTER_CITY_PINS_JSON={"baia-mare":"0000","cluj-napoca":"0000","satu-mare":"0000"}

# ==============================
# Opționale
# ==============================
# TTL tokenuri în secunde (default: 86400 = 24h).
TAXI_AUTH_TOKEN_TTL_SEC=86400

# Portul HTTP + WS (default: 3001).
PORT=3001
