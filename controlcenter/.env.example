# controlcenter/.env.example
# Copiază în controlcenter/.env.local și completează valorile.
# Next.js încarcă .env.local automat.

# ==============================
# Client-side (inlined la build; cer restart next dev la schimbare)
# ==============================
# Token public Mapbox — obligatoriu pentru harta live (components/ops/map/OpsMapCanvas.tsx).
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token

# URL-ul WebSocket al API-ului. Opțional local — fallback: ws://localhost:3001/ws.
NEXT_PUBLIC_TAXI_WS_URL=ws://localhost:3001/ws

# ==============================
# Server-side (Next API proxies din pages/api/*)
# ==============================
# Baza HTTP a API-ului Express. Opțional local — fallback: http://localhost:3001.
TAXI_API_BASE_URL=http://localhost:3001

# NOTĂ: proxy-ul pages/api/fleet/[cityId].ts citește deocamdată API_BASE_URL (divergență
# cunoscută, se aliniază în taxi-005 / #19). Local nu contează — ambele au fallback localhost.
