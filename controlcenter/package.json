{
  "name": "taxi-platform-made-by-konceptid",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run format:check && npm run check && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "type-check": "npm run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint --if-present",
    "preview": "next dev -p 3002",
    "check:all": "npm run format:check && npm run typecheck && npm run lint"
  },
  "dependencies": {
    "@taxi/shared": "file:../packages/shared",
    "@taxi/tokens": "file:../packages/tokens",
    "@vanilla-extract/css": "^1.17.4",
    "@vanilla-extract/next-plugin": "^2.4.14",
    "framer-motion": "^12.23.12",
    "mapbox-gl": "^3.18.1",
    "next": "15.5.12",
    "next-pwa": "^0.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/node": "^20.19.11",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "critters": "^0.0.23",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.12",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": "20.x"
  }
}
